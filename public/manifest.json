  "screenshots": [
    {
      "src": "/screenshots/discover.png",
      "sizes": "390x844",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Discover your echoes"
    },
    {
      "src": "/screenshots/booth.png",
      "sizes": "390x844",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Listening booths"
    },
    {
      "src": "/screenshots/journal.png",
      "sizes": "390x844",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Listening journal"
    }
  ],
  "shortcuts": [
    {
      "name": "My Booth",
      "short_name": "Booth",
      "description": "Open your listening booth",
      "url": "/booth",
      "icons": [{ "src": "/icons/shortcut-booth.png", "sizes": "96x96" }]
    },
    {
      "name": "Write in Journal",
      "short_name": "Journal",
      "description": "Add a journal entry",
      "url": "/journal/new",
      "icons": [{ "src": "/icons/shortcut-journal.png", "sizes": "96x96" }]
    },
    {
      "name": "Explore Echoes",
      "short_name": "Echoes",
      "description": "Find your resonance matches",
      "url": "/echoes",
      "icons": [{ "src": "/icons/shortcut-echoes.png", "sizes": "96x96" }]
    }
  ],
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=app.ichos",
      "id": "app.ichos"
    }
  ],
  "prefer_related_applications": false,
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+ichos",
      "url": "/handle?url=%s"
    }
  ]
}
