  "scope": "/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone"],
  "background_color": "#070604",
  "theme_color": "#070604",
  "orientation": "portrait-primary",
  "lang": "en",
  "dir": "ltr",
  "categories": ["music", "social", "lifestyle"],
